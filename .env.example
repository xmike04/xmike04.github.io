# Copy this file to `.env.local` and fill in real values.
# `.env*` is gitignored, so your real keys are never committed.
# Do NOT put real secrets in this file — it is committed as documentation only.

# REQUIRED (server-side only). Powers the AI chatbot via /api/chat.
# Read exclusively on the server in src/ai/flows/positive-chatbot.ts —
# never exposed to the browser. Without it, the chatbot returns a friendly
# "unavailable" message instead of live answers.
OPENAI_API_KEY=

# Optional. Overrides the chat model (defaults to "gpt-4o-mini").
OPENAI_MODEL=

# Optional. Canonical site URL used for metadata, sitemap.xml, and robots.txt
# (see src/app/layout.tsx, sitemap.ts, robots.ts). Example: https://example.com
NEXT_PUBLIC_SITE_URL=

# Optional. GitHub personal access token (no scopes needed for public repos).
# Raises the GitHub REST API rate limit for the repository showcase section.
GITHUB_TOKEN=
