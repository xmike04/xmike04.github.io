# Copy this file to `.env.local` and fill in real values.
# `.env*` is gitignored, so your real keys are never committed.
# Do NOT put real secrets in this file — it is committed as documentation only.

# Server-side key for the AI chatbot (OpenAI-compatible). Required for the
# chatbot / /api/chat route to return live responses. Read only on the server
# in src/ai/flows/positive-chatbot.ts — never exposed to the browser.
OPENAI_API_KEY=

# Optional. Overrides the default chat model (defaults to "gpt-5.4-mini").
OPENAI_MODEL=

# Optional. Only needed if you run the Genkit / Google AI flows (src/ai/genkit.ts).
GEMINI_API_KEY=
